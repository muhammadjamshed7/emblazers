# ============================================
# EMBLAZERS SCHOOL MANAGEMENT SYSTEM
# Environment Configuration Example
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit .env to version control (already in .gitignore)
#
# ============================================

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Client URL for CORS
CLIENT_URL=http://localhost:5000

# ============================================
# DATABASE - MONGODB (REQUIRED)
# ============================================
# Get your MongoDB connection string from:
# https://cloud.mongodb.com/
# 
# Steps:
# 1. Create a free MongoDB Atlas account
# 2. Create a new cluster
# 3. Create a database user
# 4. Get the connection string (Connect -> Drivers -> Copy)
# 5. Replace <password> with your actual password
# 6. Replace <database> with 'emblazers'
#
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/emblazers?retryWrites=true&w=majority

# ============================================
# SECURITY - JWT SECRET (REQUIRED)
# ============================================
# Generate a secure random string using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# Or use online generator: https://randomkeygen.com/
#
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ============================================
# OPTIONAL CONFIGURATIONS
# ============================================

# PostgreSQL (Currently not in active use)
# DATABASE_URL=postgresql://user:password@localhost:5432/emblazers
